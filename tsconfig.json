{
  "compilerOptions": {
    "lib": ["ESNext"],
    "types": ["@types/bun"],
    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "allowJs": true,

    "moduleResolution": "bundler",
    "paths": {
      "agent-worker": ["./packages/agent-worker/src/index.ts"],
      "@agent-worker/agent": ["./packages/agent/src/index.ts"],
      "@agent-worker/loop": ["./packages/loop/src/index.ts"],
      "@agent-worker/shared": ["./packages/shared/src/index.ts"],
      "@agent-worker/workspace": ["./packages/workspace/src/index.ts"]
    },
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,

    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,

    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noPropertyAccessFromIndexSignature": false
  }
}
