{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": null,
  "jsPlugins": ["./.oxlint/plugins/oxlint-plugin-english.js"],
  "categories": {},
  "rules": {
    "no-unused-vars": "warn",
    "no-debugger": "warn",
    "no-console": "warn",
    "no-warning-comments": "warn",
    "english-only/no-non-english-comments": "error",
    "@typescript-eslint/no-explicit-any": "error",
    "@typescript-eslint/no-unsafe-assignment": "warn",
    "@typescript-eslint/no-unsafe-member-access": "warn",
    "@typescript-eslint/no-unsafe-call": "warn",
    "@typescript-eslint/no-unsafe-return": "warn"
  },
  "settings": {},
  "env": {
    "builtin": true
  },
  "globals": {},
  "ignorePatterns": [
    "node_modules",
    "dist",
    "vendor",
    "coverage",
    "*.tsbuildinfo",
    "playwright-report",
    "test-results"
  ]
}
